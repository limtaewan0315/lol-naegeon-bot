# 디스코드 봇 토큰 (Discord Developer Portal > Bot > Reset Token)
DISCORD_BOT_TOKEN=여기에_봇_토큰_입력

# 디스코드 서버(길드) ID
GUILD_ID=여기에_서버_ID_입력

# 음성 채널 ID
BLUE_CHANNEL_ID=여기에_블루팀_채널ID_입력
RED_CHANNEL_ID=여기에_레드팀_채널ID_입력

# Supabase 연결 정보 (Supabase 대시보드 > Settings > API)
SUPABASE_URL=여기에_supabase_url_입력
SUPABASE_KEY=여기에_supabase_anon_key_입력
